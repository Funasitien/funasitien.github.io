---
import { Icon } from "astro-icon/components";

const {
  title,
  icon,
  icon_color,
  description,
  href = "#",
  width = "2",
  height = "2",
  color = "bg-base-100 border-base-300",
} = Astro.props;

// Map numeric width/height to full Tailwind grid classes so the compiler detects them
const colSpanMap: Record<string, string> = {
  "1": "md:col-span-1",
  "2": "md:col-span-2",
  "3": "md:col-span-3",
  "4": "md:col-span-4",
};

const rowSpanMap: Record<string, string> = {
  "1": "md:row-span-1",
  "2": "md:row-span-2",
  "3": "md:row-span-3",
  "4": "md:row-span-4",
};

const colClass = colSpanMap[width] || "md:col-span-2";
const rowClass = rowSpanMap[height] || "md:row-span-2";
const sizeClass = `col-span-1 ${colClass} row-span-1 ${rowClass}`;
---
<a href={href} class={`border-2 ${color} ${sizeClass} p-4 rounded-2xl h-full hover:scale-105 transition-transform duration-300`}>
    <div class="flex mb-2">
        <div class={`h-7 w-7 flex items-center justify-center p-1 mr-1 rounded ${icon_color}`}>
            {
                icon.includes("/") ?
                <img src={icon} alt={title} class="h-full w-auto" /> :
                <Icon name={icon} class="text-3xl" />
            }
        </div>
        <h2 class="text-lg font-bold">{title}</h2>
    </div>
    {description ? <p>{description}</p> : "e"}
</a>