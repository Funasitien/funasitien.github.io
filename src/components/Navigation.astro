---
import PageList from "./PageList.astro";
const currentPath = Astro.url.pathname;
---

<PageList title="Accueil" icon="gravity-ui:house" href="/" selected={currentPath === "/"} />
<PageList title="Projets" icon="gravity-ui:folder-open" href="/projets" selected={currentPath === "/projets"} />
<PageList title="Blog" icon="gravity-ui:pencil" href="/blog" selected={currentPath === "/blog"} />
<PageList title="Contact" icon="gravity-ui:envelope" href="/contact" selected={currentPath === "/contact"} />
