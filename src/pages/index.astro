---
import Layout from "../layouts/default.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Accueil">
    <div class="md:py-8 md:px-32">
        <div class="bg-[url('/banners/classic.png')] h-32 md:h-64 bg-cover bg-center rounded-lg border-2 border-neutral-content p-4">
        </div>
        <div class="mt-8 py-8 text-center">
            <h1 class="text-4xl font-bold">Funasitien</h1>
            <p class="text-lg text-base-content/70 mt-2">Bienvenue sur mon site personnel !</p>
            <div class="flex flex-col md:flex-row gap-4 justify-center mt-4">
                <a href="/projets" class="btn md:w-48">
                    <Icon name="gravity-ui:circle-number-1" class="inline mr-2 text-lg" />
                    Premier Bouton 
                </a>
                <a href="https://go.funa.dev" class="btn md:w-48">
                    <Icon name="gravity-ui:link" class="inline mr-2 text-lg" />
                    Mes Réseaux
                </a>
            </div>
        </div>
        <div class="divider magic text-base-content/20">Here lies a wonderful citation</div>
        <div class="mt-8 py-8">
            <h1 class="text-4xl font-bold">À Propos de moi</h1>
            <p class="text-lg text-base-content/70 mt-2">Bienvenue sur mon site personnel !</p>
        </div>
    </div>
</Layout>
