---
import Head from "./head.astro";
import Navigation from "../components/Navigation.astro";
import Dock from "../components/Dock.astro";
import { Icon } from "astro-icon/components";

const {
  title = "Funasitien",
  description = "Funasitien's super dupper website is amazing !",
} = Astro.props;

// Initialize variables outside try block so they're accessible in the template
let accname = "Rien pour le moment";
let status = "offline";

try {
  // Import fetch with custom SSL handling
  const fetch = (await import('node-fetch')).default;
  const https = await import('https');
  
  // Create custom agent that ignores SSL errors
  const httpsAgent = new https.Agent({
    rejectUnauthorized: false
  });

  const response = await fetch("https://api.lanyard.rest/v1/users/574169911782277135", {
    agent: httpsAgent
  });

  //if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

  let data = await response.json();
  data = data["data"];
  status = data["discord_status"];
  const activities = data["activities"];
  
  if (activities.length > 0) {
    for (const activity of activities) {
      if (activity.id === "custom") {
        accname = activity.state;
        break; // Exit loop once found
      }
    }
  }

} catch (e) {
  console.error('Error while fetching user data:', e);
}
---

<html
  lang="fr"
  data-theme="light"
  class="md:bg-base-300 selection:bg-sky-200 selection:text-sky-700 transition-colors duration-1000 ease-in-out"
>
  <head>
    <Head title={title} description={description} />
  </head>
  <body class="bg-base-300 min-h-screen flex flex-col md:py-4">
    <div
      class="fixed top-0 left-0 w-64 h-full z-50 p-4 pt-4 hidden lg:flex flex-col border-2 border-transparent"
    >
      <div class="flex-1">
        <Navigation />
      </div>
      <a
        class="flex items-center rounded-xl border-2 transition-all duration-300 ease-in-out bg-base-100 border-neutral-content"
      >
      <div class="relative ml-4 mr-1">
        <img
          src="https://github.com/Funasitien.png"
          alt="Avatar"
          class="w-10 h-10 rounded-full"
        />
        {status === "online" ? (
          <div aria-label="status" class="status status-success status-md absolute z-60 bottom-0.5 right-0.5"></div>
        ) : status === "idle" ? (
          <div aria-label="status" class="status status-warning status-md absolute z-60 bottom-0.5 right-0.5"></div>
        ) : status === "dnd" ? (
          <div aria-label="status" class="status status-error status-md absolute z-60 bottom-0.5 right-0.5"></div>
        ) : (
          <div aria-label="status" class="status status-neutral status-md absolute z-60 bottom-0.5 right-0.5"></div>
        )}
        </div>
        <div class="p-2">
          <h3 class="font-semibold">Funasitien</h3>
          <p class="text-xs -translate-y-1">{ accname }</p>
        </div>
      </a>
    </div>
    <div
      class="flex-1 bg-base-100 md:border-2 border-neutral-content md:rounded-xl md:mx-48 lg:mx-64 p-4 overflow-y-auto max-sm:pb-20"
    >
      <slot />
    </div>
    <div
      class="fixed top-0 right-0 w-64 h-full z-50 p-4 pt-4 flex flex-col border-2 border-transparent"
    >
    <div class="md:flex-1">
    </div>
    <div class="flex md:py-2">
      <div class="flex-1">
      </div>
      <label class="swap swap-rotate">
      <input type="checkbox" id="theme_switcher"/>
      <Icon
        name="gravity-ui:sun"
        class=" swap-on fill-current text-5xl p-2 max-sm:bg-base-100 max-sm:border-2 border-neutral-content max-sm:rounded-lg"
      />
      <Icon
        name="gravity-ui:moon"
        class="swap-off fill-current text-5xl p-2 max-sm:bg-base-100 max-sm:border-2 border-neutral-content max-sm:rounded-lg"
      />
    </label>
      
    </div>
    </div>
    <Dock />
    <script type="module" is:inline data-astro-rerun>
  
  if (localStorage.getItem("theme") === "dark") {
    document.getElementById("theme_switcher").checked = true;
  }
  document
    .getElementById("theme_switcher")
    ?.addEventListener("change", (e) => {
      const theme = e.target.checked ? "dark" : "light";
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
    });
</script>
  </body>
</html>
